{
  "$id": "https://dedi.global/membership.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Membership",
  "description": "This schema is used to represent public membership or affiliation status of a person or entity.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "membership_id": {
      "type": "string",
      "description": "Unique membership identifier within a namespace."
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "suspended",
        "expired",
        "revoked"
      ],
      "description": "Current membership status."
    },
    "issuer": {
      "type": "string",
      "description": "Identifier of the authority publishing the membership state."
    },
    "detail": {
      "type": "object",
      "description": "Public details of the member.",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "address": {
          "type": "string"
        },
        "publicKey": {
          "type": "string",
          "description": "URL/URI pointing to a DeDi public-key record or equivalent identifier."
        }
      },
      "required": [
        "name"
      ]
    },
    "evidence": {
      "type": "string",
      "description": "Evidence of membership, such as a URI or document identifier."
    },
    "memberSince": {
      "type": "string",
      "format": "date"
    },
    "memberTill": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "membership_id",
    "status",
    "issuer",
    "detail"
  ]
}